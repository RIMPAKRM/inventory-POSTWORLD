# ---- Build artifacts ----
/build/
/out/
/bin/

# ---- Gradle ----
.gradle/
build/
**/build/
!gradle/wrapper/gradle-wrapper.jar

# Keep wrapper jar if committed
gradle/wrapper/gradle-wrapper.jar

# Files generated by Gradle
gradle-app.setting
.gradle/caches/**
.gradle/native/**
.gradle/daemon/**
.gradle/worker/**
.gradle/fileHashes.lock
.gradle/taskArtifacts.bin
.gradle/compileBuildCache/**

# ---- IDEs ----
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/

# Eclipse
.settings/
.project
.classpath

# ---- OS files ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon

# ---- Minecraft/Forge and runtime ----
/run/
run-data/
/logs/
/crash-reports/

# Forge generated mapping artifacts
*output.srg
*output.tsrg

# ---- Gradle plugin / IntelliJ build outputs ----
out/

# ---- Test results ----
**/test-results/
**/build/test-results/
**/build/reports/tests/

# ---- Temporary and swap files ----
tmp/
**/*~
**/*.swp
**/*.swo
**/.DS_Store
**/.idea/**

# ---- Generated sources notionally excluded (e.g. via IDEs) ----
src/generated/

# ---- Misc ----
*~
*.log
*.tmp
*.temp

# Ignore local user properties
local.properties

# Java PKCS12 key store files
*.jks

# Gradle wrapper output
gradle-wrapper.properties

# If using IntelliJ with workspace settings
*.iml
.idea/**
